@@ -93,9 +94,18 @@ export default function App() {
     setShowReport(false);
   };
 
-  // Load week order on mount / week change
+  // Load week order + home modes on mount / week change
   useEffect(() => {
     setWeekOrder(getWeekOrder(currentWeekKey));
+    // Load all home modes for this week
+    const modes = {};
+    WORKOUT_PLAN.forEach(d => {
+      const key = `${currentWeekKey}-${d.id}`;
+      try {
+        modes[key] = localStorage.getItem(`gym:home-${currentWeekKey}-${d.id}`) === "1";
+      } catch { modes[key] = false; }
+    });
+    setHomeModes(modes);
   }, [currentWeekKey]);
 
   // Ordered plan for current week
@@ -124,7 +134,8 @@ export default function App() {
     const session     = getSession(targetWeek, day.id);
     const comment     = getComment(targetDate);
     const sportsForDate = getSportsForDate(targetDate);
-    const isHome      = getHomeMode(targetWeek, day.id);
+    const homeModeKey = `${targetWeek}-${day.id}`;
+    const isHome      = homeModes[homeModeKey] || false;
 
     return (
       <DayView
@@ -146,6 +157,7 @@ export default function App() {
         isHome={isHome}
         onToggleHome={(val) => {
           setHomeMode(targetWeek, day.id, val);
+          setHomeModes(prev => ({ ...prev, [homeModeKey]: val }));
         }}
       />
     );
@@ -320,7 +332,7 @@ export default function App() {
               const isToday     = day.id === WORKOUT_PLAN[todayGymIndex]?.id;
